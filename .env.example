# Public site URL (no trailing slash) — used for OAuth redirect URI construction
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Coinbase Developer Platform — OAuth2 app (https://portal.cdp.coinbase.com/)
# Redirect URI must be exactly: {NEXT_PUBLIC_APP_URL}/api/auth/coinbase/callback
COINBASE_CLIENT_ID=
COINBASE_CLIENT_SECRET=

# Optional overrides (defaults match current Coinbase App OAuth2 docs)
# COINBASE_AUTH_URL=https://login.coinbase.com/oauth2/auth
# COINBASE_TOKEN_URL=https://login.coinbase.com/oauth2/token
# COINBASE_USER_URL=https://api.coinbase.com/v2/user
# COINBASE_OAUTH_SCOPE=wallet:user:read

# iron-session — minimum 32 characters; use: openssl rand -base64 32
IRON_SESSION_PASSWORD=
